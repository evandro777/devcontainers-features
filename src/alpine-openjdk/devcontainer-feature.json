{
    "name": "Alpine openjdk",
    "id": "alpine-openjdk",
    "version": "0.0.2",
    "description": "Installs openjdk on alpine",
    "options": {
        "version": {
            "type": "string",
            "enum": [
                "openjdk17",
                "openjdk17-jre",
                "openjdk17-jre-headless",
                "openjdk17-jdk",
                "openjdk21",
                "openjdk21-jre",
                "openjdk21-jre-headless",
                "openjdk21-jdk",
                "openjdk25",
                "openjdk25-jre",
                "openjdk25-jre-headless",
                "openjdk25-jdk"
            ],
            "default": "openjdk25-jre-headless",
            "description": "Choose openjdk version."
        }
    },
    "installsAfter": [
        "ghcr.io/devcontainers/features/common-utils"
    ]
}
